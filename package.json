{
  "name": "@devleaf-labs/jarspec",
  "version": "2.0.1",
  "workspaces": [
    "packages/*",
    "test"
  ],
  "license": "MIT",
  "devDependencies": {
    "mtsl": "^0.0.11",
    "publint": "^0.3.21",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "workspace:build": "bun run --filter '@devleaf-labs/jarspec-*' build",
    "workspace:link-common": "bunx mtsl startwithoutadd -s ./common -d ./packages/js-client/src/common & bunx mtsl startwithoutadd -s ./common -d ./packages/js-server/src/common &",
    "lint:pkg": "publint packages/js-client && publint packages/js-server"
  }
}
